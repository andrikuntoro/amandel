# =============================================
# AMANDEL – Environment Variables
# Copy ke backend/.env dan isi nilai aslinya
# =============================================

# --- Database (Supabase) ---
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres"

# --- Redis (Upstash) ---
# Isi SALAH SATU: Upstash (production) atau REDIS_URL (local Docker)
UPSTASH_REDIS_REST_URL="https://[ID].upstash.io"
UPSTASH_REDIS_REST_TOKEN="[TOKEN]"
# REDIS_URL="redis://localhost:6379"   # local only

# --- JWT ---
JWT_SECRET="ganti-dengan-random-string-minimal-32-karakter"
JWT_EXPIRES_IN="7d"

# --- App ---
NODE_ENV="production"
PORT=4000
FRONTEND_URL="https://amandel.netlify.app"

# --- Email (Gmail App Password) ---
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="amandel@axamandiri.co.id"
SMTP_PASS="xxxx-xxxx-xxxx-xxxx"
SMTP_FROM="Amandel <amandel@axamandiri.co.id>"

# --- Komunitas ---
COMMUNITY_INVITE_CODE="AMANDEL2025"
AXA_EMAIL_DOMAIN="axamandiri.co.id"
